{
  "manifest_version": 3,
  "name": "GitHub PR Filler",
  "version": "1.0.0",
  "description": "Auto-fills GitHub PR title, description, reviewers, and labels based on branch name and your saved settings.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/compare/*"],
      "js": ["src/content/index.js"]
    }
  ],
  "host_permissions": ["https://github.com/*"]
}
