{
  "manifest_version": 3,
  "name": "GitHub PR Filler",
  "version": "1.0",
  "description": "Automatically fills the PR",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/compare/*"],
      "js": ["src/content/index.js"]
    }
  ],
  "host_permissions": ["https://github.com/*"]
}
